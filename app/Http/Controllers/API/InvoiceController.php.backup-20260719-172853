<?php

namespace App\Http\Controllers\API;

use App\Http\Controllers\API\BaseController as BaseController;
use App\Models\Invoice;
use App\Models\Property;
use App\Notifications\PropertyInvoiceNotification;
use Carbon\Carbon;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\Log;
use Illuminate\Support\Facades\Notification;
use Illuminate\Support\Facades\Route;
use Illuminate\Support\Facades\URL;
use Illuminate\Support\Facades\Validator;
use Throwable;

class InvoiceController extends BaseController
{
    /**
     * Display invoices for the selected date range.
     */
    public function index(Request $request)
    {
        $validator = Validator::make($request->all(), [
            'property_id' => 'nullable|integer|exists:properties,id',
            'payment_status' => 'nullable|string|max:50',
            'invoice_status' => 'nullable|string|max:50',
            'from_date' => 'nullable|date',
            'to_date' => 'nullable|date|after_or_equal:from_date',
            'date_from' => 'nullable|date',
            'date_to' => 'nullable|date|after_or_equal:date_from',
            'month' => 'nullable|date_format:Y-m',
            'per_page' => 'nullable|integer|min:1|max:100',
        ]);

        if ($validator->fails()) {
            return $this->sendError(
                'Validation Error.',
                $validator->errors(),
                422
            );
        }

        $data = $validator->validated();

        [$fromDate, $toDate] = $this->resolveDateRange($data);

        $query = Invoice::query()
            ->with([
                'property:id,title,address,location,manager_name,manager_email,property_email',
            ])
            ->latest('id');

        if ($request->filled('property_id')) {
            $query->where(
                'property_id',
                $request->integer('property_id')
            );
        }

        if (
            $request->filled('payment_status')
            && $request->input('payment_status') !== 'all'
        ) {
            $query->where(
                'payment_status',
                $request->input('payment_status')
            );
        }

        if (
            $request->filled('invoice_status')
            && $request->input('invoice_status') !== 'all'
        ) {
            $query->where(
                'invoice_status',
                $request->input('invoice_status')
            );
        }

        $query
            ->whereDate(
                'invoice_date',
                '>=',
                $fromDate->toDateString()
            )
            ->whereDate(
                'invoice_date',
                '<=',
                $toDate->toDateString()
            );

        $invoices = $query->paginate(
            min(
                max(
                    (int) $request->input('per_page', 20),
                    1
                ),
                100
            )
        );

        $invoices->setCollection(
            $invoices
                ->getCollection()
                ->map(
                    fn (Invoice $invoice) =>
                        $this->transformInvoice($invoice)
                )
        );

        return $this->sendResponse(
            $invoices,
            'Invoices retrieved successfully.'
        );
    }

    /**
     * Display one invoice inside the authenticated dashboard.
     */
    public function show(Invoice $invoice)
    {
        $invoice->load([
            'property:id,title,address,location,manager_name,manager_email,property_email',
        ]);

        return $this->sendResponse(
            $this->transformInvoice($invoice),
            'Invoice retrieved successfully.'
        );
    }

    /**
     * Public, safe invoice information for:
     *
     * /invoices/{invoice}/pay
     *
     * Do not expose private metadata or internal invoice details here.
     */
    public function publicShow(Invoice $invoice)
    {
        $invoice->load([
            'property:id,title,address,location,manager_name,property_email',
        ]);

        return $this->sendResponse(
            $this->transformInvoice(
                $invoice,
                true
            ),
            'Invoice retrieved successfully.'
        );
    }

    /**
     * Create or update a property invoice and send it by email.
     *
     * PropertyInvoiceNotification will later:
     * - render the clean invoice email;
     * - attach the generated PDF;
     * - include Pay Now and Download PDF links.
     */
    public function pushPropertyInvoice(
        Request $request,
        Property $property
    ) {
        $validator = Validator::make(
            $request->all(),
            [
                'invoice_id' =>
                    'nullable|string|max:255',
                'amount' =>
                    'nullable|numeric|min:0',
                'invoice_date' =>
                    'nullable|date',
                'due_date' =>
                    'nullable|date',
                'force' =>
                    'nullable|boolean',

                'balance_carried_forward' =>
                    'nullable|numeric|min:0',
                'vat' =>
                    'nullable|numeric|min:0',
                'adjustments' =>
                    'nullable|numeric',
                'credits' =>
                    'nullable|numeric|min:0',
            ]
        );

        if ($validator->fails()) {
            return $this->sendError(
                'Validation Error.',
                $validator->errors(),
                422
            );
        }

        $data = $validator->validated();

        $recipient = $this->cleanEmail(
            $property->property_email
        );

        $managerCc = $this->cleanEmail(
            $property->manager_email
        );

        if (!$recipient) {
            return $this->sendError(
                'Property email not found.',
                [
                    'property_email' => [
                        'Please add a valid property email before pushing invoice.',
                    ],
                ],
                422
            );
        }

        $invoiceDate = $this->parseDate(
            $data['invoice_date'] ?? null,
            now()
        );

        $dueDate = $this->parseDate(
            $data['due_date'] ?? null,
            now()->addDays(7)
        );

        $invoiceNumber = trim(
            (string) ($data['invoice_id'] ?? '')
        );

        if ($invoiceNumber === '') {
            /*
             * Keep an internal unique number in the database.
             * The email and PDF use a clean ASH reference instead,
             * so INV-PROP-... is not displayed to the customer.
             */
            $invoiceNumber = Invoice::makeInvoiceNumber(
                $property,
                $dueDate
            );
        }

        $amount = array_key_exists('amount', $data)
            ? (float) $data['amount']
            : (float) ($property->price ?? 0);

        $invoice = Invoice::updateOrCreate(
            [
                'invoice_number' => $invoiceNumber,
            ],
            [
                'property_id' => $property->id,
                'property_name' => $property->title,
                'manager_name' => $property->manager_name,
                'property_email' => $recipient,
                'manager_email' => $managerCc,
                'amount' => $amount,
                'currency' => 'RWF',
                'invoice_date' =>
                    $invoiceDate->toDateString(),
                'due_date' =>
                    $dueDate->toDateString(),
                'invoice_status' =>
                    Invoice::INVOICE_STATUS_ISSUED,
                'payment_status' =>
                    Invoice::PAYMENT_STATUS_UNPAID,
                'metadata' => [
                    'force_pushed' =>
                        (bool) ($data['force'] ?? true),
                    'source' =>
                        'manual_push',
                    'balance_carried_forward' =>
                        (float) (
                            $data['balance_carried_forward']
                            ?? 0
                        ),
                    'vat' =>
                        (float) ($data['vat'] ?? 0),
                    'adjustments' =>
                        (float) (
                            $data['adjustments']
                            ?? 0
                        ),
                    'credits' =>
                        (float) ($data['credits'] ?? 0),
                ],
            ]
        );

        try {
            $invoice->load([
                'property:id,title,address,location,manager_name,manager_email,property_email',
            ]);

            Notification::route(
                'mail',
                $recipient
            )->notify(
                new PropertyInvoiceNotification(
                    $invoice,
                    'invoice'
                )
            );

            $invoice->forceFill([
                'sent_at' => now(),
            ])->save();

            $freshInvoice = $invoice->fresh([
                'property:id,title,address,location,manager_name,manager_email,property_email',
            ]);

            return $this->sendResponse(
                [
                    'invoice' =>
                        $this->transformInvoice(
                            $freshInvoice
                        ),
                    'recipient' => $recipient,
                    'cc' => $managerCc,
                    'payment_url' =>
                        $this->paymentPageUrl(
                            $freshInvoice
                        ),
                    'pdf_url' =>
                        $this->temporaryPdfUrl(
                            $freshInvoice
                        ),
                ],
                'Invoice pushed successfully to '
                    . $recipient
                    . '.'
            );
        } catch (Throwable $exception) {
            Log::error(
                'Invoice push failed.',
                [
                    'property_id' => $property->id,
                    'invoice_id' => $invoice->id,
                    'invoice_number' =>
                        $invoice->invoice_number,
                    'error' =>
                        $exception->getMessage(),
                ]
            );

            return $this->sendError(
                'Invoice email could not be sent.',
                [
                    'mail' => [
                        $exception->getMessage(),
                    ],
                ],
                500
            );
        }
    }

    /**
     * Manual paid action for a property row.
     */
    public function markPropertyPaid(
        Request $request,
        Property $property
    ) {
        $validator = Validator::make(
            $request->all(),
            [
                'invoice_id' =>
                    'nullable|string|max:255',
                'amount' =>
                    'nullable|numeric|min:0',
                'invoice_date' =>
                    'nullable|date',
                'due_date' =>
                    'nullable|date',
                'payment_date' =>
                    'nullable|date',
                'payment_method' =>
                    'nullable|string|max:100',
                'force' =>
                    'nullable|boolean',
            ]
        );

        if ($validator->fails()) {
            return $this->sendError(
                'Validation Error.',
                $validator->errors(),
                422
            );
        }

        $data = $validator->validated();

        $recipient = $this->cleanEmail(
            $property->property_email
        );

        $managerCc = $this->cleanEmail(
            $property->manager_email
        );

        $invoiceDate = $this->parseDate(
            $data['invoice_date'] ?? null,
            now()
        );

        $dueDate = $this->parseDate(
            $data['due_date'] ?? null,
            now()->addDays(7)
        );

        $paymentDate = $this->parseDate(
            $data['payment_date'] ?? null,
            now()
        );

        $invoiceNumber = trim(
            (string) ($data['invoice_id'] ?? '')
        );

        if ($invoiceNumber === '') {
            $invoiceNumber = Invoice::makeInvoiceNumber(
                $property,
                $dueDate
            );
        }

        $amount = array_key_exists('amount', $data)
            ? (float) $data['amount']
            : (float) ($property->price ?? 0);

        $invoice = Invoice::updateOrCreate(
            [
                'invoice_number' => $invoiceNumber,
            ],
            [
                'property_id' => $property->id,
                'property_name' => $property->title,
                'manager_name' => $property->manager_name,
                'property_email' => $recipient,
                'manager_email' => $managerCc,
                'amount' => $amount,
                'currency' => 'RWF',
                'invoice_date' =>
                    $invoiceDate->toDateString(),
                'due_date' =>
                    $dueDate->toDateString(),
                'invoice_status' =>
                    Invoice::INVOICE_STATUS_ISSUED,
                'payment_status' =>
                    Invoice::PAYMENT_STATUS_PAID,
                'metadata' => [
                    'source' =>
                        'manual_paid',
                    'payment_date' =>
                        $paymentDate->toDateString(),
                    'payment_method' =>
                        trim(
                            (string) (
                                $data['payment_method']
                                ?? 'manual'
                            )
                        ),
                    'force' =>
                        (bool) ($data['force'] ?? true),
                    'payments' => $amount,
                ],
            ]
        );

        $invoice->load([
            'property:id,title,address,location,manager_name,manager_email,property_email',
        ]);

        return $this->sendResponse(
            [
                'invoice' =>
                    $this->transformInvoice($invoice),
            ],
            'Invoice marked as paid successfully.'
        );
    }

    /**
     * Mark an existing invoice as paid.
     */
    public function markPaid(
        Request $request,
        Invoice $invoice
    ) {
        $validator = Validator::make(
            $request->all(),
            [
                'payment_date' =>
                    'nullable|date',
                'payment_method' =>
                    'nullable|string|max:100',
            ]
        );

        if ($validator->fails()) {
            return $this->sendError(
                'Validation Error.',
                $validator->errors(),
                422
            );
        }

        $data = $validator->validated();

        $paymentDate = $this->parseDate(
            $data['payment_date'] ?? null,
            now()
        );

        $metadata = is_array($invoice->metadata)
            ? $invoice->metadata
            : [];

        $metadata['payment_date'] =
            $paymentDate->toDateString();

        $metadata['payment_method'] = trim(
            (string) (
                $data['payment_method']
                ?? 'manual'
            )
        );

        $metadata['payments'] =
            (float) $invoice->amount;

        $invoice->forceFill([
            'payment_status' =>
                Invoice::PAYMENT_STATUS_PAID,
            'metadata' => $metadata,
        ])->save();

        $invoice->load([
            'property:id,title,address,location,manager_name,manager_email,property_email',
        ]);

        return $this->sendResponse(
            $this->transformInvoice($invoice),
            'Invoice marked as paid successfully.'
        );
    }

    /**
     * Invoice totals for the selected date range.
     */
    public function summary(Request $request)
    {
        $validator = Validator::make(
            $request->all(),
            [
                'from_date' =>
                    'nullable|date',
                'to_date' =>
                    'nullable|date|after_or_equal:from_date',
                'date_from' =>
                    'nullable|date',
                'date_to' =>
                    'nullable|date|after_or_equal:date_from',
                'month' =>
                    'nullable|date_format:Y-m',
            ]
        );

        if ($validator->fails()) {
            return $this->sendError(
                'Validation Error.',
                $validator->errors(),
                422
            );
        }

        [$fromDate, $toDate] = $this->resolveDateRange(
            $validator->validated()
        );

        $query = Invoice::query()
            ->whereDate(
                'invoice_date',
                '>=',
                $fromDate->toDateString()
            )
            ->whereDate(
                'invoice_date',
                '<=',
                $toDate->toDateString()
            );

        $totalInvoiceValue = (float) (
            clone $query
        )->sum('amount');

        $paidAmount = (float) (
            clone $query
        )
            ->where(
                'payment_status',
                Invoice::PAYMENT_STATUS_PAID
            )
            ->sum('amount');

        $outstandingAmount = max(
            $totalInvoiceValue - $paidAmount,
            0
        );

        return $this->sendResponse(
            [
                'from_date' =>
                    $fromDate->toDateString(),
                'to_date' =>
                    $toDate->toDateString(),
                'invoice_value' =>
                    round($totalInvoiceValue, 2),
                'paid_amount' =>
                    round($paidAmount, 2),
                'outstanding_amount' =>
                    round($outstandingAmount, 2),
                'invoices_count' =>
                    (clone $query)->count(),
                'paid_count' =>
                    (clone $query)
                        ->where(
                            'payment_status',
                            Invoice::PAYMENT_STATUS_PAID
                        )
                        ->count(),
            ],
            'Invoice summary retrieved successfully.'
        );
    }

    /**
     * Convert an invoice into a consistent API response.
     */
    private function transformInvoice(
        Invoice $invoice,
        bool $public = false
    ): array {
        $invoice->loadMissing('property');

        $property = $invoice->property;

        $response = [
            'id' => $invoice->id,
            'property_id' => $invoice->property_id,
            'property_name' =>
                $invoice->property_name
                    ?: optional($property)->title,
            'manager_name' =>
                $invoice->manager_name
                    ?: optional($property)->manager_name,
            'amount' => (float) $invoice->amount,
            'currency' =>
                $invoice->currency ?: 'RWF',
            'invoice_date' =>
                optional($invoice->invoice_date)
                    ->toDateString(),
            'due_date' =>
                optional($invoice->due_date)
                    ->toDateString(),
            'invoice_status' =>
                $invoice->invoice_status,
            'payment_status' =>
                $invoice->payment_status,
            'payment_url' =>
                $this->paymentPageUrl($invoice),
            'pdf_url' =>
                $this->temporaryPdfUrl($invoice),
            'property' => $property
                ? [
                    'id' => $property->id,
                    'title' => $property->title,
                    'address' => $property->address,
                    'location' => $property->location,
                ]
                : null,
        ];

        if (!$public) {
            $response['invoice_number'] =
                $invoice->invoice_number;

            $response['property_email'] =
                $invoice->property_email;

            $response['manager_email'] =
                $invoice->manager_email;

            $response['metadata'] =
                $invoice->metadata;

            $response['sent_at'] =
                $invoice->sent_at;

            $response['created_at'] =
                $invoice->created_at;

            $response['updated_at'] =
                $invoice->updated_at;
        }

        return $response;
    }

    /**
     * Frontend payment page.
     */
    private function paymentPageUrl(
        Invoice $invoice
    ): string {
        $frontendUrl = rtrim(
            (string) env(
                'APP_FRONTEND_URL',
                'https://www.d.ashbhub.com'
            ),
            '/'
        );

        $storedPaymentUrl = trim(
            (string) (
                $invoice->getAttribute('payment_url')
                ?: $invoice->getAttribute('checkout_url')
                ?: ''
            )
        );

        if ($storedPaymentUrl !== '') {
            return $storedPaymentUrl;
        }

        return $frontendUrl
            . '/invoices/'
            . $invoice->id
            . '/pay';
    }

    /**
     * Temporary signed link to download the PDF.
     *
     * Returns null until the invoices.pdf web route is added.
     */
    private function temporaryPdfUrl(
        Invoice $invoice
    ): ?string {
        if (!Route::has('invoices.pdf')) {
            return null;
        }

        return URL::temporarySignedRoute(
            'invoices.pdf',
            now()->addDays(30),
            [
                'invoice' => $invoice->id,
            ]
        );
    }

    /**
     * Resolve invoice list date filters.
     */
    private function resolveDateRange(
        array $data
    ): array {
        if (!empty($data['month'])) {
            $fromDate = Carbon::createFromFormat(
                'Y-m',
                (string) $data['month']
            )->startOfMonth();

            $toDate = Carbon::createFromFormat(
                'Y-m',
                (string) $data['month']
            )->endOfMonth();

            return [$fromDate, $toDate];
        }

        $rawFromDate = $data['from_date']
            ?? $data['date_from']
            ?? null;

        $rawToDate = $data['to_date']
            ?? $data['date_to']
            ?? null;

        $fromDate = $rawFromDate
            ? Carbon::parse(
                (string) $rawFromDate
            )->startOfDay()
            : now()->startOfMonth();

        $toDate = $rawToDate
            ? Carbon::parse(
                (string) $rawToDate
            )->endOfDay()
            : now()->endOfDay();

        if ($toDate->lt($fromDate)) {
            $toDate = $fromDate
                ->copy()
                ->endOfDay();
        }

        return [$fromDate, $toDate];
    }

    /**
     * Parse a supplied date or use the fallback.
     */
    private function parseDate(
        ?string $value,
        Carbon $fallback
    ): Carbon {
        $value = trim(
            (string) ($value ?? '')
        );

        if ($value === '') {
            return $fallback->copy();
        }

        try {
            return Carbon::parse($value);
        } catch (Throwable) {
            return $fallback->copy();
        }
    }

    /**
     * Return a valid email or null.
     */
    private function cleanEmail(
        ?string $email
    ): ?string {
        $email = trim(
            (string) ($email ?? '')
        );

        return filter_var(
            $email,
            FILTER_VALIDATE_EMAIL
        )
            ? $email
            : null;
    }
}